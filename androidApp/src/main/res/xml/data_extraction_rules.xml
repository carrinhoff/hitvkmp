<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto-backup is disabled so fresh installs always start clean.
    EncryptedSharedPreferences + the SQLDelight DB were persisting across
    uninstalls via Google's auto-backup, which made schema upgrades break
    the app (old tables restored without the new columns).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
